#!/bin/bash
# Wave test: verify Rocky Linux test VMs (role_test_vm_rocky) are accessible via SSH
# after vms.proxmox.from-web.rocky wave completes.
set -euo pipefail
GIT_ROOT="$(git rev-parse --show-toplevel)"
. "$GIT_ROOT/set_env.sh"
SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"
. "$_UTILITIES_DIR/bash/init.sh"

export PYTHON_VERSION='python3.12'
INVENTORY_FILE="${_DYNAMIC_DIR}/ansible/inventory/hosts.yml"

_activate_ansible_locally "$(dirname "$(dirname "$SCRIPT_DIR")")"
ansible-galaxy collection install community.sops --upgrade 2>/dev/null | grep -v "already installed" || true

ANSIBLE_HOST_KEY_CHECKING=False \
ANSIBLE_PYTHON_INTERPRETER=auto \
    ansible-playbook --inventory "${INVENTORY_FILE}" "${SCRIPT_DIR}/playbook.yaml"
