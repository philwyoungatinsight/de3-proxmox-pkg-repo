#!/bin/bash

################################################################################
# Boiler plate
################################################################################

# uncomment this to for debugging
#set -x

# Aggressively catch and report errors
set -euo pipefail
function handle_error {
    local exit_status=$?
    echo "An error occurred on line $LINENO: $BASH_COMMAND"
    exit $exit_status
}
trap handle_error ERR

# Set Config variables
GIT_ROOT="$(git rev-parse --show-toplevel)"
. "$GIT_ROOT/set_env.sh"

# Path to this script
SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"

# Utility functions
. $_UTILITIES_DIR/bash/init.sh
. $_UTILITIES_DIR/bash/framework-utils.sh

################################################################################
# Use our own Python and Ansible (not the OS)
################################################################################

export PYTHON_VERSION='python3.12'

# Path to the shared Ansible inventory generated by generate_ansible_inventory.
INVENTORY_FILE="${_DYNAMIC_DIR}/ansible/inventory/hosts.yml"

setup_python() {
    VENV_PARENT_DIR="$SCRIPT_DIR"
    _activate_ansible_locally "$VENV_PARENT_DIR"
}

################################################################################
# Functions
################################################################################

function show_usage()
{
    printf "Usage: $0 <command>\n"
    cat <<EOF
    -b|--build      Generate inventory then install Proxmox VE on proxmox_server hosts
    -t|--test       Verify Proxmox VE is running (loops until all checks pass or timeout)
    -d|--deps       Install Python and Ansible requirements only
    -c|--clean      Remove generated tmp files
    -C|--clean-all  Remove tmp files and the Python virtual environment
    -s|--status     Show the current inventory file
    -h|--help       Show this help

    Environment variables:
      _PROXMOX_VE_WAIT_TIMEOUT  Timeout in seconds for --test polling loop
                                  0  = skip verification immediately
                                 -1  = wait indefinitely (no timeout)
                                  N  = poll for up to N seconds (default: 600)

    Example:
      $0 -b
      $0 -t
      _PROXMOX_VE_WAIT_TIMEOUT=0 $0 -b   # install without waiting for services
EOF
  exit 1
}

if [[ $# -lt 1 ]]; then
    show_usage "$@"
fi

# Install required Ansible collections
install_collections() {
    ansible-galaxy collection install community.sops --upgrade
}

# Run an Ansible playbook against the dynamic inventory.
# Sets ANSIBLE_HOST_KEY_CHECKING=False to avoid interactive SSH prompts.
run_ansible() {
    local PLAYBOOK="$1"
    shift
    cd "$SCRIPT_DIR"
    ANSIBLE_HOST_KEY_CHECKING=False \
    ANSIBLE_PYTHON_INTERPRETER=auto \
        ansible-playbook --inventory "${INVENTORY_FILE}" "$PLAYBOOK" "$@"
}

# Generate the shared Ansible inventory from Terraform state.
generate_inventory() {
    echo "Generating Ansible inventory..."
    "$_GENERATE_INVENTORY" --build
}

# Check command for wait_for_condition: run the test playbook once.
# Returns 0 if all Proxmox assertions pass, non-0 otherwise.
_proxmox_ve_running() {
    run_ansible "playbook.install-proxmox-test.yaml" 2>&1 | tail -5
    return "${PIPESTATUS[0]}"
}

################################################################################
# Boiler plate make targets
################################################################################

function deps() {
    echo "deps"
    setup_python
    install_collections
}

function build() {
    echo "build"
    setup_python
    install_collections
    generate_inventory
    run_ansible "playbook.install-proxmox.yaml"
}

function clean() {
    echo "clean"
    rm -rf "${SCRIPT_DIR}/tmp"
}

function clean_all() {
    echo "clean_all"
    clean
    rm -rf "${SCRIPT_DIR}/.venv"
}

function test_app() {
    echo "test"
    setup_python
    install_collections
    if [ ! -f "${INVENTORY_FILE}" ]; then
        echo "Inventory not found at ${INVENTORY_FILE}. Generating..."
        generate_inventory
    fi
    # Loop until the Proxmox verification playbook passes or the timeout is reached.
    # _PROXMOX_VE_WAIT_TIMEOUT controls the polling behaviour (default: 600 seconds).
    if ! wait_for_condition \
        "Proxmox VE services running on proxmox_server hosts" \
        "_proxmox_ve_running" \
        _PROXMOX_VE_WAIT_TIMEOUT 600 30; then
        echo "ERROR: Proxmox VE services did not become healthy within the configured timeout."
        exit 1
    fi
    echo "Proxmox VE verification passed."
}

function show_status() {
    echo "status"
    if [ -f "${INVENTORY_FILE}" ]; then
        echo "Inventory file: ${INVENTORY_FILE}"
        cat "${INVENTORY_FILE}"
    else
        echo "No inventory file found at ${INVENTORY_FILE}"
        echo "Run './run --build' to generate it."
    fi
}

################################################################################
# Process run arguments
################################################################################
while [[ $# -gt 0 ]]; do
  key="$1"

  case $key in
    -c|--clean)
        shift
        clean
        ;;
    -C|--clean-all)
        shift
        clean_all
        ;;
    -b|--build)
        shift
        build
        ;;
    -s|--status)
        shift
        show_status
        ;;
    -t|--test)
        shift
        test_app
        ;;
    -d|--deps)
        shift
        deps
        ;;
    -h|--help)
        show_usage
      ;;
    *)
      shift # ignore
      ;;
  esac
done
