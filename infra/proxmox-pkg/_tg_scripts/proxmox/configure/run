#!/bin/bash

################################################################################
# Boiler plate
################################################################################

# uncomment this to for debugging
#set -x

# Aggressively catch and report errors
set -euo pipefail
function handle_error {
    local exit_status=$?
    echo "An error occurred on line $LINENO: $BASH_COMMAND"
    exit $exit_status
}
trap handle_error ERR

# Set Config variables
GIT_ROOT="$(git rev-parse --show-toplevel)"
. "$GIT_ROOT/set_env.sh"

# Path to this script
SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"

# Utility functions
. $_UTILITIES_DIR/bash/init.sh

################################################################################
# Use our own Python and Ansible (not the OS)
################################################################################

export PYTHON_VERSION='python3.12'

# Path to the shared Ansible inventory generated by generate_ansible_inventory.
# PVE hosts appear there as the 'pve_hosts' group alongside VM groups.
PVE_INVENTORY_FILE="${_DYNAMIC_DIR}/ansible/inventory/hosts.yml"

setup_python() {
    VENV_PARENT_DIR="$SCRIPT_DIR"
    _activate_ansible_locally "$VENV_PARENT_DIR"
}

################################################################################
# Functions
################################################################################

function show_usage()
{
    printf "Usage: $0 <command>\n"
    cat <<EOF
    -b|--build      Generate shared Ansible inventory then configure hosts (storage, token, networking)
    -t|--test       Verify bridge config (generates inventory if missing)
    -d|--deps       Install Python and Ansible requirements only
    -c|--clean      Remove generated tmp files
    -C|--clean-all  Remove tmp files and the Python virtual environment
    -s|--status     Show the current PVE inventory file
    -h|--help       Show this help

    Example:
      $0 -b
EOF
  exit 1
}

if [[ $# -lt 1 ]]; then
    show_usage "$@"
fi

# Install required Ansible collections
install_collections() {
    ansible-galaxy collection install community.sops --upgrade
}

# Run an Ansible playbook against the PVE host inventory.
# Sets ANSIBLE_HOST_KEY_CHECKING=False to avoid interactive SSH prompts.
run_ansible() {
    local PLAYBOOK="$1"
    cd "$SCRIPT_DIR"
    ANSIBLE_HOST_KEY_CHECKING=False \
    ANSIBLE_PYTHON_INTERPRETER=auto \
        ansible-playbook --inventory "${PVE_INVENTORY_FILE}" "$PLAYBOOK"
}

# Generate the shared Ansible inventory (includes pve_hosts group from YAML config).
generate_inventory() {
    echo "Generating Ansible inventory..."
    "$_GENERATE_INVENTORY" --build
}

################################################################################
# Boiler plate make targets
################################################################################

function deps() {
    echo "deps"
    setup_python
    install_collections
}

function build() {
    echo "build"
    setup_python
    install_collections
    generate_inventory
    run_ansible "playbook.configure-pve.yaml"
}

function clean() {
    echo "clean"
    rm -rf "${SCRIPT_DIR}/tmp"
}

function clean_all() {
    echo "clean_all"
    clean
    rm -rf "${SCRIPT_DIR}/.venv"
}

function test_app() {
    echo "test"
    setup_python
    install_collections
    if [ ! -f "${PVE_INVENTORY_FILE}" ]; then
        echo "Inventory not found at ${PVE_INVENTORY_FILE}. Generating..."
        generate_inventory
    fi
    run_ansible "playbook.configure-pve-test.yaml"
}

function show_status() {
    echo "status"
    if [ -f "${PVE_INVENTORY_FILE}" ]; then
        echo "Inventory file: ${PVE_INVENTORY_FILE}"
        cat "${PVE_INVENTORY_FILE}"
    else
        echo "No inventory file found at ${PVE_INVENTORY_FILE}"
        echo "Run './run --build' to generate it."
        echo "(Shared inventory is generated by scripts/common/generate-ansible-inventory)"
    fi
}

################################################################################
# Process run arguments
################################################################################
while [[ $# -gt 0 ]]; do
  key="$1"

  case $key in
    -c|--clean)
        shift
        clean
        ;;
    -C|--clean-all)
        shift
        clean_all
        ;;
    -b|--build)
        shift
        build
        ;;
    -s|--status)
        shift
        show_status
        ;;
    -t|--test)
        shift
        test_app
        ;;
    -d|--deps)
        shift
        deps
        ;;
    -h|--help)
        show_usage
      ;;
    *)
      shift # ignore
      ;;
  esac
done
